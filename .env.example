# ProtonVPN WireGuard credentials
# Get your private key: protonvpn.com → Downloads → WireGuard → Generate config → copy PrivateKey from [Interface]
PROTON_WG_PRIVATE_KEY=your_wireguard_private_key_here

# Optional: comma-separated country names to select VPN server
# See: github.com/qdm12/gluetun/wiki/ProtonVPN for full list
PROTON_SERVER_COUNTRIES=Netherlands

# Optional: path for downloads ZFS bind mount
DOWNLOADS_PATH=./downloads

# Optional: gluetun control server credentials (defaults to xdcc/xdcc)
GLUETUN_CONTROL_USER=xdcc
GLUETUN_CONTROL_PASS=xdcc
